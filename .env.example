# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# (legacy Fase 0)
# ENTSO-E Transparency Platform API Token
# Ottenere da https://transparency.entsoe.eu/ dopo registrazione
ENTSOE_API_TOKEN=your_token_here

# Resend (email transactional per form Contatti EIDX Pro)
# 1. Sign up su https://resend.com (free tier: 3.000 email/mese)
# 2. Verifica il dominio mittente (es. energyindex.it o energyindex.pro)
#    oppure usa "onboarding@resend.dev" per test (limite 100/giorno)
# 3. Genera API key da https://resend.com/api-keys
# 4. Aggiungi qui sotto (e nelle env vars Netlify per produzione)
RESEND_API_KEY=re_your_api_key_here
# Mittente delle email Contatti — DEVE essere un indirizzo del dominio verificato.
# Default fallback: onboarding@resend.dev (per test iniziale, no verification needed)
RESEND_SENDER_EMAIL="EIDX Pro <noreply@energyindex.it>"
